# Application related
PORT=3000
NODE_ENV=production
TOKENX_LOGGER_LOG_LEVEL=info

MONGO_SSLCA=

# Uygulama URI'ye şunu ekler: /<MONGO_DATABASE> (MONGO_URL'de veritabanı adı path olarak vermeyin).
MONGO_DATABASE=defter

# Railway MONGO_INITDB_ROOT_* / kök kullanıcı: kimlik bilgisi `admin` DB'dedir; path `defter` olsa bile gerekir.
MONGO_AUTH_SOURCE=admin

# --- Uzak MongoDB (Docker'daki API uzaktaki cluster'a bağlanır) ---
# Şifrede @ : / # ? gibi karakterler varsa mutlaka URL-encode edin.
# Atlas'ta kullanıcı çoğu zaman `admin` veritabanındadır; bağlantı reddedilirse authSource ekleyin:
# MONGO_URL=mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&authSource=admin
# Atlas Network Access: çıkış IP'niz (veya test için 0.0.0.0/0) izinli olmalı.
MONGO_URL=

# --- Sadece docker-compose `mongo` servisi (profile: local) için; uzak DB kullanıyorsanız gerekmez ---
# MONGO_ROOT_USERNAME=root
# MONGO_ROOT_PASSWORD=defterlocal
# Yerel mongo örneği: MONGO_URL=mongodb://root:defterlocal@mongo:27017

MONGO_CONNECT_TIMEOUT_MS=3000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_MAX_TIME_MS=10000
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=0

# Admin auth related
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_JWT_SECRET=change-me