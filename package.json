{
  "name": "tokenx-energy-basket",
  "version": "0.4.0",
  "author": "emre.ozkaya",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@8.14.1",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:integration": "jest --config ./jest.config.integration.js --runInBand",
    "test:integration:cov": "jest --config ./jest.config.integration.js --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "10.4.21",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "10.4.21",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.0.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "dotenv": "17.2.3",
    "kafkajs": "^2.2.4",
    "mongoose": "9.1.4",
    "nestjs-pino": "4.5.0",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.1.0",
    "@commitlint/config-conventional": "20.0.0",
    "@faker-js/faker": "10.1.0",
    "@jest/globals": "30.2.0",
    "@nestjs/cli": "11.0.14",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.9",
    "@swc/cli": "0.7.9",
    "@swc/core": "1.15.3",
    "@types/axios": "0.14.4",
    "@types/express": "4.17.25",
    "@types/express-session": "1.18.2",
    "@types/jest": "30.0.0",
    "@types/node": "24.10.1",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "async-mutex": "0.5.0",
    "axios": "1.13.2",
    "cd": "0.3.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsonc": "2.21.0",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "jest-html-reporters": "3.1.7",
    "jest-junit": "16.0.0",
    "jsonc-eslint-parser": "^2.4.2",
    "prettier": "3.7.4",
    "semver": "7.7.3",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "timekeeper": "2.3.1",
    "ts-jest": "29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.53.1"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "build",
          "ci",
          "chore",
          "revert"
        ]
      ]
    }
  }
