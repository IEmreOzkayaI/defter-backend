#!/bin/bash

# Define colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

abort() {
    echo -e "${RED}❌ Pre-commit operation aborted.${NC}"
    echo
    exit 1
}

# Detect direct commit with -m flag by checking message format
COMMIT_MSG=$(cat "$1")
COMMITIZEN_PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)\([a-z-]+\): .+"

# Skip if running from semantic-release
if [ "$HUSKY_SKIP" = "1" ]; then
  exit 0
fi

# Skip if running from semantic-release
if [ "$HUSKY_SKIP" = "1" ]; then
  exit 0
fi

# Use 'grep' for better compatibility with regex
if ! [[ $COMMIT_MSG =~ $COMMITIZEN_PATTERN ]]; then
  echo -e "⛔ Commit message does not follow the required format."
  echo
  echo -e "Please use our commit tools instead:"
  echo -e "  pnpm commit - Interactive commit message creation"
  echo -e "  pnpm save   - Add, commit with wizard, and push"
  echo
  exit 1
fi

# If we get here, continue with standard commitlint validation
echo -e "${YELLOW}🚀 Commit check starting...${NC}"
echo
npx --no -- commitlint --edit $1 || abort
echo -e "${GREEN}✅ Commit check completed successfully!${NC}"
echo